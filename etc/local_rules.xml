<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>


  <!-- Agent offline gap detection (generated by agent_offline_tracker) -->
  <!-- Fires when wazuh-remoted detects an agent reconnect after a gap   -->
  <!-- during which the agent's local buffer may have overflowed.         -->
  <rule id="100100" level="8">
    <match>wazuh-remoted: Agent offline gap detected</match>
    <description>Agent offline gap detected: events during offline window may be missing. $(agent.name) was offline for a significant period.</description>
    <group>agent_offline,data_integrity,</group>
  </rule>

  <!-- Low-severity variant for brief gaps (1–5 minutes)                 -->
  <rule id="100101" level="5">
    <if_sid>100100</if_sid>
    <regex>offline for (?:6[0-9]|[1-2][0-9]{2}|3[0-5][0-9]) second</regex>
    <description>Agent offline gap (brief): $(agent.name) offline &lt;6 minutes, events may be partially captured.</description>
    <group>agent_offline,</group>
  </rule>

</group>
